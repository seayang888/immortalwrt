CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_xiaomi_mi-router-ax3000t=y

# ===== 基础系统 =====
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_ubus=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_logd=y
CONFIG_PACKAGE_urngd=y
CONFIG_PACKAGE_opkg=y

# ===== 网络核心 =====
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y

# ===== ✅ 完整 nft / netfilter（绝对不要删）=====
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-nat=y

CONFIG_PACKAGE_kmod-nft-socket=y
CONFIG_PACKAGE_kmod-nft-fib=y
CONFIG_PACKAGE_kmod-nft-tproxy=y

# 👉 TProxy 必备
CONFIG_PACKAGE_kmod-ipt-tproxy=y

# ===== 网络驱动（Filogic 必备）=====
CONFIG_PACKAGE_kmod-mt7530=y
CONFIG_PACKAGE_kmod-mt753x=y
CONFIG_PACKAGE_kmod-dsa-mt7530=y
CONFIG_PACKAGE_kmod-mdio-devres=y
CONFIG_PACKAGE_kmod-phy-realtek=y

# ===== LuCI =====
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# ===== OpenClash =====
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_openclash_core=n

# ===== Passwall（稳定版）=====
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_xray-core=y

# ===== ❌ 禁用 Rust 系 =====
CONFIG_PACKAGE_sing-box=n
CONFIG_PACKAGE_hysteria=n
CONFIG_PACKAGE_v2ray-core=n
CONFIG_PACKAGE_v2ray-plugin=n
CONFIG_PACKAGE_rust=n
CONFIG_PACKAGE_cargo=n

# ===== 工具 =====
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_kmod-tun=y

# ===== IPv6（必须保留）=====
CONFIG_IPV6=y
CONFIG_PACKAGE_ipv6helper=y

# ===== 优化 =====
CONFIG_STRIP_KERNEL_EXPORTS=y
CONFIG_USE_MKLIBS=y
CONFIG_USE_STRIP=y

# ===== 禁用无用组件 =====
CONFIG_PACKAGE_ppp=n
CONFIG_USB_SUPPORT=n

# ===== 防止编译炸 =====
CONFIG_PACKAGE_fwupd-libs=n
CONFIG_PACKAGE_FWUPD_PLUGIN_FLASHROM=n
