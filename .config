# 1. 硬件型号（切换为 112M 大分区方案，注意不要带 stock-layout）
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_xiaomi_mi-router-ax3000t=y

# 2. 核心界面与语言
CONFIG_PACKAGE_luci=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_uhttpd=y

# 3. OpenClash 及其全能内核 (112M 空间足够，全部预装，开箱即用)
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_OpenClash_CORE_MIPSEL=n
CONFIG_PACKAGE_OpenClash_CORE_ARMV7=n
CONFIG_PACKAGE_OpenClash_CORE_ARMV8=y
CONFIG_PACKAGE_OpenClash_CORE_META=y
CONFIG_PACKAGE_OpenClash_CORE_TUN=y

# 4. PassWall 及其常用组件
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox=y

# 5. 性能优化与基础工具
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-i18n-turboacc-zh-cn=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_unzip=y
